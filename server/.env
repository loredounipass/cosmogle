# Server environment variables
# Port the server listens on
PORT=8000

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Comma-separated allowed origins for CORS (add your client URLs)
ALLOWED_ORIGINS=https://shiny-waffle-rqr4g6grxq9fpwj4-5173.app.github.dev

# TURN server — Servidor Local Docker (Coturn)
# IMPORTANTE: Si usas DevTunnels o quieres conectarte desde otra red, cambia 'localhost' por tu IP pública
# y asegúrate de abrir los puertos UDP/TCP 3478 y UDP 49152-49160 en tu router.
TURN_URL=https://shiny-waffle-rqr4g6grxq9fpwj4-3478.app.github.dev
TURN_USERNAME=strangers
TURN_CREDENTIAL=strangers123

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Logging configuration
LOG_LEVEL=INFO
LOG_COLORS=true
LOG_JSON=false

NODE_ENV=production